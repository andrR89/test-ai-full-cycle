{
  "name": "backend",
  "version": "1.0.0",
  "description": "Express backend API",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest --runInBand --forceExit",
    "test:coverage": "jest --runInBand --forceExit --coverage"
  },
  "dependencies": {
    "dotenv": "16.4.5",
    "express": "4.19.2"
  },
  "devDependencies": {
    "jest": "29.7.0",
    "nodemon": "3.1.4",
    "supertest": "7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ]
  }
}
